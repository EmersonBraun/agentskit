[0.003, "o", "\u001b[34m?\u001b[39m \u001b[1mTemplate:\u001b[22m\r\n\u001b[36m❯ React chat (Vite + browser)\u001b[39m\r\n  Ink chat (terminal UI)\r\n  Runtime (headless agent, no UI)\r\n  Multi-agent (planner + delegates)\r\n\r\n\u001b[36mStreaming UI with @agentskit/react\u001b[39m\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[2.047, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[32m✔\u001b[39m \u001b[1mTemplate:\u001b[22m \u001b[36mReact chat (Vite + browser)\u001b[39m\u001b[40G"]
[0.001, "o", "\r\n\u001b[?25h"]
[0.000, "o", "\u001b[34m?\u001b[39m \u001b[1mLLM provider:\u001b[22m\r\n\u001b[36m❯ Demo (no API key — deterministic stub)\u001b[39m\r\n  OpenAI\r\n  Anthropic\r\n  Gemini\r\n  Ollama (local, no key)\r\n\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[1.805, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[32m✔\u001b[39m \u001b[1mLLM provider:\u001b[22m \u001b[36mDemo (no API key — deterministic stub)\u001b[39m\u001b[55G"]
