    "fumadocs-core": "^16.7.15",
    "fumadocs-mdx": "^14.3.0",
    "fumadocs-ui": "^16.7.15",
    "mermaid": "^11.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typedoc": "^0.28.19",
