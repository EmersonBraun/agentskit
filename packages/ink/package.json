{
  "name": "@agentskit/ink",
  "version": "0.4.0",
  "description": "Ink terminal components and hooks for AgentsKit.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*",
    "ink": "^5.1.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "react": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  }
}
