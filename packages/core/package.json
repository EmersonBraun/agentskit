{
  "name": "@agentskit/core",
  "version": "1.5.0",
  "description": "Portable AgentsKit runtime for chat orchestration, tools, memory, and retrieval.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "orchestration",
    "streaming",
    "tools",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "autonomous-agents",
    "zero-dependencies",
    "edge-runtime"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./agent-schema": {
      "types": "./dist/agent-schema.d.ts",
      "import": "./dist/agent-schema.js",
      "require": "./dist/agent-schema.cjs"
    },
    "./prompt-experiments": {
      "types": "./dist/prompt-experiments.d.ts",
      "import": "./dist/prompt-experiments.js",
      "require": "./dist/prompt-experiments.cjs"
    },
    "./auto-summarize": {
      "types": "./dist/auto-summarize.d.ts",
      "import": "./dist/auto-summarize.js",
      "require": "./dist/auto-summarize.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "stable",
    "stabilityNote": "Sacred package. Contract-stable per ADRs 0001-0006."
  }
}
