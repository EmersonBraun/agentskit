{
  "name": "@agentskit/core",
  "version": "0.4.2",
  "description": "Portable AgentsKit runtime for chat orchestration, tools, memory, and retrieval.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "orchestration",
    "streaming",
    "tools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
