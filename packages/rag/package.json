{
  "name": "@agentskit/rag",
  "version": "0.1.2",
  "description": "Plug-and-play retrieval-augmented generation for AgentsKit.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "rag",
    "retrieval",
    "embeddings"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "stable",
    "stabilityNote": "Retriever contract v1. Ingest + retrieve shipped."
  }
}
