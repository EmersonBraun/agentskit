{
  "name": "@agentskit/cli",
  "version": "0.4.0",
  "description": "CLI for AgentsKit chat and project scaffolding.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentskit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/adapters": "workspace:*",
    "@agentskit/core": "workspace:*",
    "@agentskit/ink": "workspace:*",
    "@agentskit/skills": "workspace:*",
    "@agentskit/tools": "workspace:*",
    "commander": "^14.0.1",
    "ink": "^6.8.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
