{
  "name": "@agentskit/react-native",
  "version": "0.2.1",
  "description": "React Native + Expo hook + components for AgentsKit.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "react-native",
    "expo",
    "mobile",
    "hooks"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "alpha",
    "stabilityNote": "React Native / Expo binding — same contract as @agentskit/react."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/react-native",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
