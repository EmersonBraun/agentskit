{
  "name": "agentskit",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:interop": "vitest run --config tests/vitest.config.ts",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "docs": "pnpm --filter @agentskit/docs start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@agentskit/core": "workspace:*",
    "@agentskit/runtime": "workspace:*",
    "@agentskit/tools": "workspace:*",
    "@agentskit/skills": "workspace:*",
    "@agentskit/eval": "workspace:*",
    "@agentskit/observability": "workspace:*",
    "@agentskit/templates": "workspace:*",
    "@changesets/cli": "^2.29.6",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
