{
  "name": "agentskit",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:interop": "vitest run --config tests/vitest.config.ts",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "docs": "pnpm --filter @agentskit/docs start",
    "release": "pnpm build && pnpm changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "serialize-javascript": ">=7.0.5"
    }
  },
  "devDependencies": {
    "@agentskit/core": "workspace:*",
    "@agentskit/eval": "workspace:*",
    "@agentskit/observability": "workspace:*",
    "@agentskit/runtime": "workspace:*",
    "@agentskit/skills": "workspace:*",
    "@agentskit/templates": "workspace:*",
    "@agentskit/tools": "workspace:*",
    "@changesets/cli": "2.30.0",
    "turbo": "2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
