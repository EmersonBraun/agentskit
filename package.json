{
  "name": "agentskit",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "docs": "pnpm --filter @agentskit/docs start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "serialize-javascript": ">=7.0.5"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2"
  }
}
