{
  "name": "agentskit",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:interop": "vitest run --config tests/vitest.config.ts",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "docs": "pnpm --filter @agentskit/docs-next dev",
    "docs:build": "pnpm --filter @agentskit/docs-next build",
    "docs:deploy": "pnpm --filter @agentskit/docs-next exec vercel deploy --prod --yes",
    "docs:deploy:preview": "pnpm --filter @agentskit/docs-next exec vercel deploy --yes",
    "release": "pnpm build && pnpm changeset publish",
    "size": "pnpm build && size-limit",
    "size:why": "pnpm build && size-limit --why"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "serialize-javascript": ">=7.0.5"
    }
  },
  "devDependencies": {
    "@agentskit/core": "workspace:*",
    "@agentskit/eval": "workspace:*",
    "@agentskit/observability": "workspace:*",
    "@agentskit/runtime": "workspace:*",
    "@agentskit/skills": "workspace:*",
    "@agentskit/templates": "workspace:*",
    "@agentskit/tools": "workspace:*",
    "@changesets/cli": "2.31.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "size-limit": "^12.1.0",
    "turbo": "2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
