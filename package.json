{
  "name": "react-arrow",
  "version": "0.1.0",
  "description": "A hooks-first React library for the agentic era. Inspired by Arrow.js.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs",
      "types": "./dist/adapters/index.d.ts"
    },
    "./theme": "./dist/theme/default.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^4.1.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^24.0.0"
  },
  "keywords": ["react", "ai", "chat", "streaming", "hooks", "agentic", "arrow-js"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EmersonBraun/lib"
  }
}
